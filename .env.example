# === 应用配置 ===
DEBUG=true

# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://chuma:chuma@localhost:5432/chuma

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET_KEY=change-me-in-production

# === AI 服务 ===
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TOKEN=change-me-in-production   # backend→ai 服务间认证，必须与 ai 侧 SERVICE_TOKEN 一致
SERVICE_TOKEN=change-me-in-production      # ai 侧接收用

# === 本地微调模型 ===
LOCAL_MODEL_URL=http://localhost:8002/v1
LOCAL_MODEL_NAME=chuma-finetuned

# === 快速回答模型（内网 Qwen3.5-9B）===
QUICK_MODEL_URL=http://localhost:8002/v1
QUICK_MODEL_NAME=Qwen3.5-9B

# === 远程大模型 API（DeepSeek）===
REMOTE_MODEL_API_KEY=
REMOTE_MODEL_BASE_URL=https://api.deepseek.com
REMOTE_MODEL_NAME=deepseek-v4-pro

# === DeepSeek 深度解答（与远程大模型共用）===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-v4-pro

# === 知识图谱大模型 API ===
KG_MODEL_API_KEY=
KG_MODEL_BASE_URL=https://api.deepseek.com
KG_MODEL_NAME=deepseek-v4-flash

# === ChromaDB ===
# Docker 内部通信：CHROMADB_HOST=chromadb, CHROMADB_PORT=8000
# 本地开发直连：  CHROMADB_HOST=localhost, CHROMADB_PORT=8020
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# === Apache AGE ===
AGE_HOST=localhost
AGE_PORT=5432
AGE_DB=chuma
AGE_USER=chuma
AGE_PASSWORD=change-me
AGE_GRAPH_NAME=chuma_kg

# === OCR 文档解析 ===
OCR_VLM_URL=http://localhost:8004
OCR_OUTPUT_DIR=data/ocr_output
OCR_TASK_RETENTION_SECONDS=86400
OCR_MAX_CONCURRENT=2

# === MCP 联网搜索 ===
MCP_SEARCH_URL=
MCP_SEARCH_TOKEN=
MCP_PROXY=
